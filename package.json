{
  "name": "amazon-ads-ai-control-center",
  "private": true,
  "version": "0.1.0",
  "description": "MVP foundation scaffold for the Amazon Ads AI Automation Control Center.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "test:web": "npm --workspace apps/web run test",
    "dev:api": "python -m uvicorn apps.api.app.main:app --reload --host 127.0.0.1 --port 8000",
    "test:api": "python -m pytest tests/unit tests/integration",
    "test": "python -m pytest tests/unit tests/integration && npm --workspace apps/web run test",
    "lint": "npm --workspace apps/web run lint"
  },
  "engines": {
    "node": ">=20",
    "python": ">=3.12"
  }
}
