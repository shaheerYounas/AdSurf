{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@adsurf/types": ["../../packages/types/src"],
      "@adsurf/shared": ["../../packages/shared/src"]
